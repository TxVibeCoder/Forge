# Forge — build artifacts
build/
cmake-build-*/

# Dependencies (git submodules — not committed as files)
# (JUCE / tracktion_engine added as submodules in Phase 0)

# OS cruft
.DS_Store
Thumbs.db

# IDE
.vs/
.vscode/
.idea/
*.user

# Audio render scratch
*.wav.tmp

# Runtime logs — the app logs to %APPDATA%\Forge\logs, but guard against a stray
# stderr redirect or a copied log landing in the tree (public repo: logs carry
# absolute user paths + the command line by design).
*.log
forge.log*

# Local-only notes (never published to this pseudonymous public repo).
*.local.md

# Multi-CLI wave packets — local operational scaffolding (they embed machine-local paths).
# The committed record of a wave is its consolidation devlog, not these prompt files.
wave-*-cli-prompts/
